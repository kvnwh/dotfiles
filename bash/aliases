function gc() {
    git add .
    git commit -v -a -m "$*"
}

# delete branches starting with pattern
function gb-d {
    pattern=$1
    git branch --list "$pattern*" | xargs -r git branch -D
}

function isancestor {
    if $( git merge-base --is-ancestor $1 $2 ); then
        echo "$2 already contains $1"
        # exit 0
    elif $( git merge-base --is-ancestor $2 $1 ); then
        echo "$1 already contains $2"
        # exit 0
    else
        echo "$1 and $2 are not related"
        # exit 1
    fi
}

